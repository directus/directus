		"lodash-es": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@directus/tsconfig": "catalog:",
		"@types/lodash-es": "catalog:",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"undici": "catalog:",
		"vitest": "catalog:"
	},
	"engines": {
		"node": ">=22"
	}
}
